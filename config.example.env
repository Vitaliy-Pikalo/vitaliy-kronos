# ─── Vitaliy Kronos Signal Bot — Config ───
# Copy this file to config.env and fill in your credentials
# config.env is gitignored — never commit real credentials

# Discord webhook URL
# How to get: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Gmail credentials (use an App Password, NOT your real Gmail password)
# How to get: myaccount.google.com → Security → 2-Step Verification → App passwords
# App name: "Kronos Bot" → generates 16-char password
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where to send email alerts (can be same as GMAIL_USER, or a different address)
ALERT_EMAIL=youremail@gmail.com

# Market to trade: BTC (default) or equity symbol like QQQ or SPY
SYMBOL=QQQ
